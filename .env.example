# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (for receiving notifications)
# To get your ID, send /start to the bot and it will show you
TELEGRAM_CHAT_ID=your_chat_id_here

# Data Cache Directory
DATA_DIR=./data

# Database
DB_PATH=./data/predictions.db

# Notification Settings
NOTIFICATION_TIME=09:00
NOTIFICATION_TIMEZONE=America/Argentina/Buenos_Aires

# Minimum confidence threshold for predictions (0-100)
MIN_CONFIDENCE=70

# ===================================
# APIS OPCIONALES (Mejoran el análisis)
# ===================================

# API-Football (api-football.com)
# Free tier: 100 requests/día
# Registrate en: https://www.api-football.com/
API_FOOTBALL_KEY=

# The Odds API (the-odds-api.com)
# Free tier: 500 requests/mes
# Registrate en: https://the-odds-api.com/
ODDS_API_KEY=

# Football-Data.org (football-data.org)
# Free tier: 10 requests/min
# Registrate en: https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=
